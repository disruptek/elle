digraph fiber_resume {
    rankdir=TB;
    node [shape=box, fontname="monospace", fontsize=10];
    edge [fontname="monospace", fontsize=9];
    compound=true;

    // ── Entry points ──────────────────────────────────────────────
    subgraph cluster_entry {
        label="Entry Points";
        style=dashed;

        prim_call [label="handle_primitive_signal\n(signal.rs)\nSIG_RESUME detected"];
        jit_prim [label="jit_handle_primitive_signal\n(calls.rs)\nSIG_RESUME detected"];
    }

    // ── Interpreter path ──────────────────────────────────────────
    hfrs [label="handle_fiber_resume_signal\n(fiber.rs:169)\nCall position"];
    hfrs_tail [label="handle_fiber_resume_signal_tail\n(fiber.rs:246)\nTailCall position"];
    hfrs_jit [label="handle_fiber_resume_signal_jit\n(fiber.rs:750)\nJIT context → JitValue"];

    prim_call -> hfrs [label="Call"];
    prim_call -> hfrs_tail [label="TailCall"];
    jit_prim -> hfrs_jit;

    // ── do_fiber_resume (trampoline) ──────────────────────────────
    subgraph cluster_trampoline {
        label="do_fiber_resume trampoline\n(fiber.rs:307)";
        style=rounded;
        color=blue;

        dfr [label="do_fiber_resume\n(&handle, fiber_value)"];
        dfr_single [label="do_fiber_resume_single\n(fiber.rs:420)"];
        dfr_check [label="bits == SIG_SWITCH?", shape=diamond];
        dfr_unwind [label="Unwind fiber_stack\nmask.covers(bits)?", shape=diamond];

        dfr -> dfr_single [label="first call"];
        dfr_single -> dfr_check;
        dfr_check -> dfr [label="YES: push pending\nto fiber_stack\n(loop, no recursion)", style=dashed, color=blue];
        dfr_check -> dfr_unwind [label="NO: real signal"];

        dfr_unwind -> dfr_single [label="caught:\nresume parent\n(loop back)", style=dashed, color=blue];
    }

    hfrs -> dfr [label="inline call\n(Rust stack grows)"];
    hfrs_tail -> dfr;
    hfrs_jit -> dfr;

    // ── with_child_fiber (swap protocol) ──────────────────────────
    wcf [label="with_child_fiber\n(fiber.rs:50)\nswap parent↔child fibers"];
    dfr_single -> wcf;

    // ── First vs subsequent resume ────────────────────────────────
    first_q [label="is_first_resume?", shape=diamond];
    wcf -> first_q;

    dfr_first [label="do_fiber_first_resume\n(fiber.rs:470)\nbuild_closure_env + execute"];
    dfr_subseq [label="do_fiber_subsequent_resume\n(fiber.rs:533)\ntake fiber.suspended"];

    first_q -> dfr_first [label="New"];
    first_q -> dfr_subseq [label="Paused"];

    // ── Execution ─────────────────────────────────────────────────
    exec_save [label="execute_bytecode_saving_stack\n(execute.rs:205)\nsave/restore caller stack"];
    exec_from_ip [label="execute_bytecode_from_ip\n(execute.rs:102)\nresume at saved IP"];
    dispatch [label="execute_bytecode_inner_impl\n(dispatch.rs)\nbytecode dispatch loop"];

    dfr_first -> exec_save;
    exec_save -> dispatch;

    // ── resume_suspended (frame chain replay) ─────────────────────
    subgraph cluster_resume {
        label="resume_suspended\n(core.rs:411)";
        style=rounded;
        color=darkgreen;

        rs [label="resume_suspended\n(frames, resume_value)"];
        rs_type [label="frame type?", shape=diamond];
        rs_fiber [label="SuspendedFrame::FiberResume\nset pending_fiber_resume\nreturn SIG_SWITCH"];
        rs_bc [label="SuspendedFrame::Bytecode\nrestore stack + env\npush resume_value"];

        rs -> rs_type [label="for each frame"];
        rs_type -> rs_fiber [label="FiberResume"];
        rs_type -> rs_bc [label="Bytecode"];
    }

    dfr_subseq -> rs;
    rs_bc -> exec_from_ip;
    exec_from_ip -> dispatch;

    // ── SIG_SWITCH feeds back to trampoline ───────────────────────
    rs_fiber -> dfr_check [label="SIG_SWITCH\n(via do_fiber_resume\ntrampoline loop)", style=dashed, color=red];

    // ── Dispatch can hit fiber/resume again ───────────────────────
    call_inner [label="call_inner\n(call.rs:142)\nCall instruction"];
    dispatch -> call_inner [label="Call opcode"];
    call_inner -> prim_call [label="native fn\n(fiber/resume)", style=dotted, color=red, label="  ← Rust stack\n     recursion"];

    // ── call_inner also does closures ─────────────────────────────
    call_inner -> exec_save [label="closure\n(re-entrant)"];

    // ── JIT paths ─────────────────────────────────────────────────
    subgraph cluster_jit {
        label="JIT Dispatch";
        style=dashed;
        color=purple;

        jit_call [label="elle_jit_call\n(calls.rs:175)"];
        jit_native [label="native fn dispatch\n→ jit_handle_primitive_signal"];
        jit_jit [label="JIT-to-JIT fast path\n(callee in jit_cache)"];
        jit_interp [label="interpreter fallback\n→ execute_bytecode_saving_stack"];
        jit_ytc [label="elle_jit_yield_through_call\n(suspend.rs)\nsave caller frame\n⚠ env reconstruction"];

        jit_call -> jit_native [label="NativeFn"];
        jit_call -> jit_jit [label="Closure\n(cached)"];
        jit_call -> jit_interp [label="Closure\n(no cache)"];
    }

    jit_native -> jit_prim [label="SIG_RESUME"];
    jit_interp -> exec_save [label="re-entrant"];

    // ── Top-level SIG_SWITCH handler ──────────────────────────────
    subgraph cluster_toplevel {
        label="Top-level event loops";
        style=dashed;
        color=brown;

        exec_sched [label="execute_scheduled\n(mod.rs:209)\nSIG_IO + SIG_SWITCH handler"];
        exec_bc [label="execute_bytecode\n(mod.rs:73)\nSIG_SWITCH handler"];
        hsw [label="handle_sig_switch\n(mod.rs:132)\ntake pending_fiber_resume\ntake caller_frames"];
    }

    exec_sched -> hsw [label="bits == SIG_SWITCH"];
    exec_bc -> hsw [label="bits == SIG_SWITCH"];
    hsw -> dfr [label="do_fiber_resume\n(re-entrant)"];
    hsw -> rs [label="resume_suspended\n(caller_frames, result)"];

    // ── Result paths ──────────────────────────────────────────────
    subgraph cluster_results {
        label="Result Handling";
        style=dashed;

        caught [label="caught by mask\npush value to stack\nreturn None"];
        uncaught_err [label="uncaught SIG_ERROR\nset fiber.signal\nreturn None"];
        uncaught_other [label="uncaught non-error\nbuild FiberResume +\ncaller frames\nreturn Some(bits)"];
    }

    dfr_unwind -> caught [label="caught\n(fiber_stack empty)"];
    hfrs -> caught [label="mask.covers(bits)", style=dotted];
    hfrs -> uncaught_err [label="SIG_ERROR"];
    hfrs -> uncaught_other [label="e.g. SIG_IO"];

    // ── Annotations ───────────────────────────────────────────────
    note_stack [label="Red dotted = Rust stack recursion\nBlue dashed = trampoline (iterative)\nPurple = JIT paths", shape=note, fillcolor=lightyellow, style=filled];
}
